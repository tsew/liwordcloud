{
  "name": "liwordcloud",
  "version": "1.0.0",
  "description": "An online app for generating high quality word clouds for the banners in LinkedIn Profiles",
  "scripts": {
    "dev:frontend": "cd frontend && npm start",
    "dev:backend": "cd backend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "deploy:backend": "cd backend && npm run deploy",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install"
  },
  "keywords": ["wordcloud", "linkedin", "react", "cloudflare-workers"],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsew/liwordcloud.git"
  }
}